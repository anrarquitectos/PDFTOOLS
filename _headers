/*
  # ── Clickjacking / framing ──────────────────────────────────────────────────
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff

  # ── Referrer leakage ────────────────────────────────────────────────────────
  Referrer-Policy: strict-origin-when-cross-origin

  # ── Permissions (lock down browser APIs you don't use) ───────────────────────
  # Remove or loosen entries only when a specific tool requires the API.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # ── Content-Security-Policy ──────────────────────────────────────────────────
  #
  # Notas de diseño:
  #
  # 'unsafe-inline' en script-src: necesario porque las páginas contienen grandes
  # bloques <script> inline. Para eliminarlo habría que migrar todos los scripts
  # a archivos externos y usar nonces (incompatible con Cloudflare Pages estático).
  # Es la concesión pragmática más habitual en SPAs/herramientas 100% estáticas.
  #
  # 'wasm-unsafe-eval': requerido por el motor Ghostscript compilado a WASM.
  # Sin esta directiva el engine no puede compilar los módulos .wasm en runtime.
  #
  # worker-src blob:: el worker de Ghostscript se instancia como Blob URL.
  #
  # Carbon Ads (actualmente comentado en el HTML): si lo activas, añade a
  # script-src: https://cdn.carbonads.com https://srv.carbonads.net
  # img-src:    https://cdn4.buysellads.net
  # connect-src: https://srv.carbonads.net
  #
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https://www.googletagmanager.com https://ssl.gstatic.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com; worker-src 'self' blob:; child-src blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none';
